  "question": "¿Cuáles son las raíces de la ecuación x² -10x +9 = 0?",
  "answers": [
    {
      "text": "1 y -9",
      "correct": false
    },
    {
      "text": "-1 y -9",
      "correct": false
    },
    {
      "text": "1 y 9",
      "correct": true
    },
    {
      "text": "2 y 8",
      "correct": false
    }
  ],
  "explanation": "La ecuación se factoriza como (x - 1)(x - 9) = 0, por lo que las raíces son 1 y 9.",
