  "question": "¿Cuántas direcciones IPv4 totales contiene una red /20?",
  "answers": [
    {
      "text": "8192",
      "correct": false
    },
    {
      "text": "4094",
      "correct": false
    },
    {
      "text": "4096",
      "correct": true
    },
    {
      "text": "2048",
      "correct": false
    }
  ],
  "explanation": "En IPv4, una red /20 deja 12 bits para direcciones; por tanto contiene 2^12 = 4096 direcciones.",
