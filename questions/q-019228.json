  "question": "¿Cuáles son las raíces de la ecuación x² +0x -4 = 0?",
  "answers": [
    {
      "text": "-2 y 2",
      "correct": true
    },
    {
      "text": "2 y -2",
      "correct": false
    },
    {
      "text": "-1 y 1",
      "correct": false
    },
    {
      "text": "-2 y -2",
      "correct": false
    }
  ],
  "explanation": "La ecuación se factoriza como (x - -2)(x - 2) = 0, por lo que las raíces son -2 y 2.",
