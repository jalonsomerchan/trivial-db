  "question": "¿Cuáles son las raíces de la ecuación x² +7x +6 = 0?",
  "answers": [
    {
      "text": "6 y 1",
      "correct": false
    },
    {
      "text": "-6 y 1",
      "correct": false
    },
    {
      "text": "-6 y -1",
      "correct": true
    },
    {
      "text": "-5 y -2",
      "correct": false
    }
  ],
  "explanation": "La ecuación se factoriza como (x - -6)(x - -1) = 0, por lo que las raíces son -6 y -1.",
