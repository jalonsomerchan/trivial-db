  "question": "¿Cuáles son las raíces de la ecuación x² -18x +72 = 0?",
  "answers": [
    {
      "text": "6 y 12",
      "correct": true
    },
    {
      "text": "7 y 11",
      "correct": false
    },
    {
      "text": "-6 y -12",
      "correct": false
    },
    {
      "text": "6 y -12",
      "correct": false
    }
  ],
  "explanation": "La ecuación se factoriza como (x - 6)(x - 12) = 0, por lo que las raíces son 6 y 12.",
