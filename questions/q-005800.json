    {
      "text": "Ec = 1/2·m·v²",
      "correct": true
    },
    {
      "text": "v = d/t",
      "correct": false
    },
    {
      "text": "P = W/t",
      "correct": false
    },
    {
      "text": "W = F·d",
      "correct": false
    }
  ],
  "explanation": "La expresión habitual de energía cinética es Ec = 1/2·m·v².",
